# ─── Hela Network ────────────────────────────────────────────
# Testnet RPC (EVM-compatible)
HELA_RPC_URL=https://testnet-rpc.helachain.com
# Mainnet RPC
HELA_MAINNET_RPC=https://mainnet-rpc.helachain.com

# ─── Deployer Wallet ─────────────────────────────────────────
# WARNING: Never commit this to git. Add .env to .gitignore.
PRIVATE_KEY=your_wallet_private_key_here

# ─── Gas Reporting ───────────────────────────────────────────
REPORT_GAS=true

# ─── Block Explorer (Hela Blockscout) ────────────────────────
HELA_EXPLORER_API_KEY=your_explorer_api_key_here
